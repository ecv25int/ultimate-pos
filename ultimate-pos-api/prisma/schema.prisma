  @@index([createdBy])
  @@index([createdAt])
}

model StockAdjustmentLine {
  id           Int     @id @default(autoincrement())
  adjustmentId Int     @map("adjustment_id")
  variationId  Int?    @map("variation_id")
  quantity     Decimal @db.Decimal(22, 4)
  unitPrice    Decimal @default(0) @map("unit_price") @db.Decimal(22, 4)

  adjustment StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  variation  Variation?      @relation(fields: [variationId], references: [id])

  @@map("stock_adjustment_lines")
  @@index([adjustmentId])
  @@index([variationId])
}

// ============================================
// P3: Barcode Labels
// ============================================

model BarcodeLabel {
  id          Int      @id @default(autoincrement())
  businessId  Int      @map("business_id")
  name        String   @db.VarChar(255)
  description String?  @db.Text
  stickerType String   @default("name_price") @map("sticker_type") @db.VarChar(50)
  barcodeType String   @default("C128") @map("barcode_type") @db.VarChar(20)
  width       Decimal? @db.Decimal(8, 2)
  height      Decimal? @db.Decimal(8, 2)
  paperWidth  Decimal? @map("paper_width") @db.Decimal(8, 2)
  paperHeight Decimal? @map("paper_height") @db.Decimal(8, 2)
  fontSize    Int?     @map("font_size")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("barcode_labels")
  @@index([businessId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  businessId Int      @map("business_id")
  userId     Int?     @map("user_id")
  action     String   @db.VarChar(20)
  // 'CREATE' | 'UPDATE' | 'DELETE' | 'VIEW'
  entity     String   @db.VarChar(50)
  entityId   Int?     @map("entity_id")
  meta       Json?
  ip         String?  @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
  @@index([businessId])
  @@index([businessId, entity])
  @@index([businessId, createdAt])
}

model PushSubscription {
  id         Int      @id @default(autoincrement())
  businessId Int      @map("business_id")
  userId     Int      @map("user_id")
  endpoint   String   @db.VarChar(2048)
  p256dh     String   @db.VarChar(255)
  auth       String   @db.VarChar(255)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
  @@unique([userId, endpoint(length: 255)])
  @@index([businessId])
  @@index([userId])
}

model ScheduledReport {
  id          Int      @id @default(autoincrement())
  businessId  Int      @map("business_id")
  createdBy   Int      @map("created_by")
  name        String   @db.VarChar(100)
  reportType  String   @map("report_type") @db.VarChar(50)
  // 'sales_summary' | 'profit_loss' | 'inventory' | 'expenses' | 'contacts'
  frequency   String   @db.VarChar(20)
  // 'daily' | 'weekly' | 'monthly'
  recipients  Json
  // string[] of email addresses
  isActive    Boolean  @default(true) @map("is_active")
  lastRunAt   DateTime? @map("last_run_at")
  nextRunAt   DateTime? @map("next_run_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("scheduled_reports")
  @@index([businessId])
  @@index([businessId, isActive])
}
